<launch>
    <!--启动d435_color.py节点-->
    <node pkg="lys_visp_demo" type="d435_color.py" name="d435_color_node" output="log"/>
    <!--启动apriltag_detect.py节点-->
    <node pkg="lys_visp_demo" type="apriltag_detect.py" name="apriltag_detect_node" output="log"/>
    <!--启动ethercat_socket_driver节点-->
    <node pkg="lys_visp_demo" type="ethercat_socket_driver.py" name="ethercat_socket_driver" output="screen"/>
    <!--启动jr603_ibvs_ctrl节点-->
    <node pkg="lys_visp_demo" type="jr603_ibvs_ctrl" name="jr603_ibvs_ctrl" output="log"/>
    <!--启动velocity_camera2end 节点-->
    <node pkg="lys_visp_demo" type="velocity_camera2end.py" name="velocity_camera2end" output="log"/>
    <!--启动获取关节速度节点-->
    <node pkg="lys_visp_demo" type="jr603_get_joints_velocity_ethercatV1.py" name="get_joints_velocity_node" output="screen"/>
    <!--启动joints_velocity_with_ruckig_min_duration节点-->
    <node pkg="lys_visp_demo" type="jr603_velocity_with_otg" name="otg_node" output="screen"/>
    <!--启动socket节点-->
    <node pkg="lys_visp_demo" type="jr603_socket_ethercatV2.py" name="socket_ethercat_node" output="log"/>
</launch>
